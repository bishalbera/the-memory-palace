# Copy this file to .env and fill in your values

LLM_PROVIDER=anthropic
LLM_MODEL=anthropic/claude-haiku-4-5-20251001
LLM_API_KEY=

EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

GM_MODEL=claude-sonnet-4-6

GAME_SEED=42
COGNEE_DATASET=ravenwood

# Rate limits (protect LLM credits on a public demo) — all optional, defaults shown
MAX_TURNS_PER_SESSION=30      # cap turns per game
IP_ACTIONS_PER_MIN=12         # per-IP action throttle
IP_SESSIONS_PER_HOUR=6        # per-IP new-game throttle
GLOBAL_ACTIONS_PER_DAY=200    # hard daily ceiling across all users
